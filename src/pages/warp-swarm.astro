            </tr>
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.06); background: rgba(8,20,45,0.90);">
              <td style="padding: 2px 4px 2px 8px; overflow: hidden; white-space: nowrap; width: 16px;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" style="display:block;"><circle cx="8" cy="8" r="8" fill="#007ACC"/><path fill="white" stroke="white" stroke-width="0.5" d="M11.5 11.19V4.8L7.3 7.99M1.17 6.07a.6.6 0 0 1-.01-.81L2 4.48c.14-.13.48-.18.73 0l2.39 1.83 5.55-5.09c.22-.22.61-.32 1.05-.08l2.8 1.34c.25.15.49.38.49.81v9.49c0 .28-.2.58-.42.7l-3.08 1.48c-.22.09-.64 0-.79-.14L5.11 9.69l-2.38 1.83c-.27.18-.6.13-.74 0l-.84-.77c-.22-.23-.2-.61.04-.84l2.1-1.9"/></svg></td>
