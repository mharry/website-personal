              <td style="padding: 2px 6px 2px 6px; color: rgba(255,255,255,0.70); font-size: 10px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">—</td>
              <td style="padding: 2px 6px 2px 6px; color: rgba(255,255,255,0.70); font-size: 10px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">—</td>
              <td style="padding: 2px 6px 2px 6px; overflow: hidden;"><div style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: rgba(255,255,255,0.30); font-size: 10px;">—</div></td>
