            </span>
          </div>
        </div>
        <div class="portfolioCardX right" style="width: 65%; display: flex; align-items: center; justify-content: center; padding: 8px 12px;">
          <div style="width: 100%; display: flex; align-items: center; gap: 0; background: rgba(0,15,58,0.32); border-radius: 10px; padding: 14px 12px;">
            <!-- JIRA input -->
            <div style="flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; padding: 6px 5px; border: 1.5px solid #FFC220; border-radius: 7px; background: #0a1550; min-width: 32px;">
