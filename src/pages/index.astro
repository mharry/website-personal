<script is:inline>
(function () {
  var canvas = document.getElementById('warp-bg');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W, H, cx, cy, maxDist;

  function resize() {
    W = canvas.width  = canvas.offsetWidth  || 260;
    H = canvas.height = canvas.offsetHeight || 290;
    cx = W / 2; cy = H / 2;
    maxDist = Math.hypot(cx, cy) + 200;
  }

  var PALETTES = [
    [200,230,255],[200,230,255],[200,230,255],
    [77,189,245],[77,189,245],
    [140,200,255],[255,255,255],[180,210,255],
    [255,194,32],
  ];

  function Star(preSpread) {
    this.reset(preSpread);
  }
  Star.prototype.reset = function(spread) {
    this.angle = Math.random() * Math.PI * 2;
    this.dist  = spread ? Math.random() * Math.hypot(cx, cy) * 0.85 : Math.random() * 6;
    this.speed = 0.14 + Math.random() * 0.28;
    this.size  = 0.4 + Math.random() * 0.9;
    var p = PALETTES[Math.floor(Math.random() * PALETTES.length)];
    this.r = p[0]; this.g = p[1]; this.b = p[2];
  };
  Star.prototype.update = function() {
    this.speed += this.dist * 0.0000455;
    if (this.speed > 9.8) this.speed = 9.8;
    this.dist += this.speed;
    if (this.dist > maxDist) this.reset(true);
  };
  Star.prototype.draw = function() {
    var trailBack = this.speed * 5.5;
    var prevDist  = Math.max(0, this.dist - trailBack);
    var x2 = cx + Math.cos(this.angle) * this.dist;
    var y2 = cy + Math.sin(this.angle) * this.dist;
    var x1 = cx + Math.cos(this.angle) * prevDist;
    var y1 = cy + Math.sin(this.angle) * prevDist;
    var alpha = Math.min(1, this.dist / 70) * 0.85;
    if (alpha <= 0) return;
    var lw = this.size * Math.min(2.5, 0.4 + this.dist / 180);
    var grad = ctx.createLinearGradient(x1, y1, x2, y2);
    grad.addColorStop(0, 'rgba(' + this.r + ',' + this.g + ',' + this.b + ',0)');
    grad.addColorStop(1, 'rgba(' + this.r + ',' + this.g + ',' + this.b + ',' + alpha + ')');
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.strokeStyle = grad;
    ctx.lineWidth = lw;
    ctx.stroke();
  };

  var NUM_STARS = 160;
  var stars = [];

  function init() {
    resize();
    stars = [];
    for (var i = 0; i < NUM_STARS; i++) stars.push(new Star(i < NUM_STARS * 0.75));
    ctx.fillStyle = '#000F3A';
    ctx.fillRect(0, 0, W, H);
    frame();
  }

  function frame() {
    ctx.fillStyle = 'rgba(0,15,58,0.13)';
    ctx.fillRect(0, 0, W, H);
    for (var i = 0; i < stars.length; i++) { stars[i].update(); stars[i].draw(); }
    requestAnimationFrame(frame);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<script is:inline>
(function () {
  var canvas = document.getElementById('swarm-bg');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W, H, cx, cy, nodes = [];

  var COLORS = [
    [77,  189, 245, 0.55],
    [77,  189, 245, 0.55],
    [77,  189, 245, 0.55],
    [0,   83,  226, 0.42],
    [0,   83,  226, 0.42],
    [140, 200, 255, 0.35],
    [200, 230, 255, 0.30],
    [255, 194,  32, 0.32],
  ];

  function randomSize(nearCenter) {
    var r = Math.random();
    if (r < 0.55) return 0.5  + Math.random() * 0.9;
    if (r < 0.85) return 1.8  + Math.random() * 1.4;
    if (r < 0.97) return 3.8  + Math.random() * 2.0;
    return nearCenter ? 6.5 + Math.random() * 2.5 : 3.8 + Math.random() * 2.0;
  }

  function alphaForSize(size, baseAlpha) {
    if (size < 1.4) return baseAlpha * 0.65;
    if (size < 3.2) return baseAlpha;
    if (size < 5.8) return Math.min(1, baseAlpha * 1.25);
    return Math.min(1, baseAlpha * 1.45);
  }

  function SwarmNode(x, y, nearCenter) {
    this.x = x; this.y = y;
    var numRings = 1 + Math.floor(Math.random() * (nearCenter ? 3 : 2));
    this.rings = [];
    for (var i = 0; i < numRings; i++) {
      var numDots = 2 + Math.floor(Math.random() * 3);
      var col = COLORS[Math.floor(Math.random() * COLORS.length)];
      var radius = 10 + Math.random() * (nearCenter ? 38 : 24);
      var dir = Math.random() > 0.5 ? 1 : -1;
      var speed = dir * (0.0039 + Math.random() * 0.0091);
      var sizes = [], angles = [];
      for (var k = 0; k < numDots; k++) {
        sizes.push(randomSize(nearCenter));
        angles.push((k / numDots) * Math.PI * 2 + Math.random());
      }
      this.rings.push({ radius: radius, speed: speed, angles: angles, sizes: sizes,
        r: col[0], g: col[1], b: col[2], baseAlpha: col[3] });
    }
  }
  SwarmNode.prototype.update = function() {
    for (var i = 0; i < this.rings.length; i++) {
      var ring = this.rings[i];
      for (var j = 0; j < ring.angles.length; j++) ring.angles[j] += ring.speed;
    }
  };
  SwarmNode.prototype.dots = function() {
    var out = [];
    for (var i = 0; i < this.rings.length; i++) {
      var ring = this.rings[i];
      for (var j = 0; j < ring.angles.length; j++) {
        var size = ring.sizes[j];
        out.push({
          x: this.x + Math.cos(ring.angles[j]) * ring.radius,
          y: this.y + Math.sin(ring.angles[j]) * ring.radius,
          size: size, r: ring.r, g: ring.g, b: ring.b,
          alpha: alphaForSize(size, ring.baseAlpha)
        });
      }
    }
    return out;
  };

  function buildNodes() {
    nodes = [];
    var COLS = 6, ROWS = 5;
    var cw = W / COLS, ch = H / ROWS;
    for (var row = 0; row < ROWS; row++) {
      for (var col = 0; col < COLS; col++) {
        var x = cw * col + cw * (0.12 + Math.random() * 0.76);
        var y = ch * row + ch * (0.12 + Math.random() * 0.76);
        nodes.push(new SwarmNode(x, y, Math.hypot(x - cx, y - cy) < 120));
      }
    }
    for (var i = 0; i < 10; i++) {
      var sx = Math.random() * W, sy = Math.random() * H;
      nodes.push(new SwarmNode(sx, sy, Math.hypot(sx - cx, sy - cy) < 120));
    }
  }

  var CONNECT_DIST = 72, CONNECT_DIST_SQ = 72 * 72;

  function frame() {
    ctx.fillStyle = 'rgba(14,94,78,1)';
    ctx.fillRect(0, 0, W, H);

    var allDots = [];
    for (var i = 0; i < nodes.length; i++) {
      nodes[i].update();
      var d = nodes[i].dots();
      for (var j = 0; j < d.length; j++) allDots.push(d[j]);
    }

    for (var i = 0; i < allDots.length; i++) {
      var a = allDots[i];
      for (var j = i + 1; j < allDots.length; j++) {
        var b = allDots[j];
        var dx = a.x - b.x, dy = a.y - b.y;
        if (dx * dx + dy * dy < CONNECT_DIST_SQ) {
          var prox = 1 - Math.sqrt(dx * dx + dy * dy) / CONNECT_DIST;
          ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = 'rgba(77,189,245,' + (prox * 0.13) + ')';
          ctx.lineWidth = 0.3 + Math.min(a.size, b.size) * 0.06;
          ctx.stroke();
        }
      }
    }

    for (var i = 0; i < allDots.length; i++) {
      var dot = allDots[i];
      if (dot.size >= 3.8) {
        ctx.shadowColor = 'rgba(' + dot.r + ',' + dot.g + ',' + dot.b + ',0.5)';
        ctx.shadowBlur = dot.size * 3;
      }
      ctx.beginPath(); ctx.arc(dot.x, dot.y, dot.size, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + dot.r + ',' + dot.g + ',' + dot.b + ',' + dot.alpha + ')';
      ctx.fill();
      if (dot.size >= 3.8) { ctx.shadowBlur = 0; ctx.shadowColor = 'transparent'; }
    }

    requestAnimationFrame(frame);
  }

  function resize() {
    W = canvas.width  = canvas.offsetWidth  || 260;
    H = canvas.height = canvas.offsetHeight || 290;
    cx = W / 2; cy = H / 2;
    buildNodes();
  }

  function init() { resize(); frame(); }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>
