                <div style="width: 13px; height: 1px; background: rgba(255,194,32,0.55); margin-bottom: 3px;"></div>
                <div style="width: 13px; height: 1px; background: rgba(255,194,32,0.55);"></div>
              </div>
              <span style="font-size: 8px; color: #FFC220; font-weight: 700; letter-spacing: 0.5px; white-space: nowrap;">JIRA</span>
            </div>
            <!-- Arrow -->
            <div style="flex: 0 0 16px; display: flex; align-items: center; justify-content: center;">
              <svg width="16" height="10" viewBox="0 0 16 10"><line x1="0" y1="5" x2="10" y2="5" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/><path d="M8,1 L15,5 L8,9 Z" fill="rgba(255,255,255,0.65)"/></svg>
            </div>
            <!-- Phase 1 -->
            <div class="phase-box" style="flex: 1; min-width: 0; padding: 12px 6px; background: #1a5276; border-radius: 10px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px;">
              <span style="font-size: clamp(16px, 2vw, 24px); line-height: 1;">🔨</span>
              <span style="color: white; font-size: clamp(10px, 1.3vw, 15px); font-weight: 700; white-space: nowrap;">Phase 1</span>
              <span style="color: rgba(255,255,255,0.75); font-size: clamp(9px, 1vw, 12px); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;">Build</span>
            </div>
            <!-- Arrow -->
            <div style="flex: 0 0 16px; display: flex; align-items: center; justify-content: center;">
              <svg width="16" height="10" viewBox="0 0 16 10"><line x1="0" y1="5" x2="10" y2="5" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/><path d="M8,1 L15,5 L8,9 Z" fill="rgba(255,255,255,0.65)"/></svg>
            </div>
            <!-- Phase 2 -->
            <div class="phase-box" style="flex: 1; min-width: 0; padding: 12px 6px; background: #1a5e2a; border-radius: 10px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px;">
              <span style="font-size: clamp(16px, 2vw, 24px); line-height: 1;">🔬</span>
              <span style="color: white; font-size: clamp(10px, 1.3vw, 15px); font-weight: 700; white-space: nowrap;">Phase 2</span>
              <span style="color: rgba(255,255,255,0.75); font-size: clamp(9px, 1vw, 12px); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;">Test</span>
            </div>
            <!-- Arrow -->
            <div style="flex: 0 0 16px; display: flex; align-items: center; justify-content: center;">
              <svg width="16" height="10" viewBox="0 0 16 10"><line x1="0" y1="5" x2="10" y2="5" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/><path d="M8,1 L15,5 L8,9 Z" fill="rgba(255,255,255,0.65)"/></svg>
            </div>
            <!-- Phase 3 -->
            <div class="phase-box" style="flex: 1; min-width: 0; padding: 12px 6px; background: #7d3000; border-radius: 10px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px;">
              <span style="font-size: clamp(16px, 2vw, 24px); line-height: 1;">🚀</span>
              <span style="color: white; font-size: clamp(10px, 1.3vw, 15px); font-weight: 700; white-space: nowrap;">Phase 3</span>
              <span style="color: rgba(255,255,255,0.75); font-size: clamp(9px, 1vw, 12px); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;">Deploy</span>
